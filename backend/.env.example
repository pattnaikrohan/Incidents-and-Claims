# Database Configuration
# Use SQLite for local development: sqlite:///./sql_app.db
# Use PostgreSQL/SQL Server for production
DATABASE_URL=sqlite:///./sql_app.db

# Security
# Run `openssl rand -hex 32` to generate a secure secret key
SECRET_KEY=secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# External Integration (Optional)
# For enriching incident data with job details from external SQL sources
SQL_SERVER_ENRICHMENT_URL=mssql+pyodbc://sa:YourPassword@localhost/CargoWiseDB?driver=ODBC+Driver+17+for+SQL+Server
